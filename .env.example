# Copy to backend/.env — Nest loads it via ConfigModule when you start from the backend directory (`npm run start:dev`).
PORT=4000
# Comma-separated if Next.js sometimes runs on another port (e.g. 3001 when 3000 is busy).
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Demo: send this value as Authorization: Bearer … OR use Supabase JWT after login.
# When using this token, clients must also send X-User-Id: <uuid of auth.users>
DEMO_BEARER_TOKEN=dev-demo-bearer-change-me

# Max upload size per file (MB). Must match frontend `MAX_UPLOAD_FILE_SIZE_MB` in `frontend/src/lib/maxUpload.ts`.
MAX_UPLOAD_FILE_SIZE_MB=10

# Signed URL lifetime for Storage files (seconds). Shorter = less risk if a link is leaked after access is revoked.
# Default 900 (15 min). Range 60–86400.
# SIGNED_URL_EXPIRES_SECONDS=900
